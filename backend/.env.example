# MirrorMind — Environment Configuration
# Copy to .env and fill in your values

# Postgres
POSTGRES_USER=vsl
POSTGRES_PASSWORD=vsl_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mirrormind

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# OpenAI / OpenAI-compatible provider
# For official OpenAI, just set the API key.
# For other providers (Ollama, LM Studio, Together, Groq, etc.),
# set OPENAI_API_BASE to their v1-compatible endpoint.
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o

# App
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=local-dev-change-me
