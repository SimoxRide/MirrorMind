# ═══════════════════════════════════════════════════════════════
# MirrorMind — Environment Configuration
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────────
# Values: development | production | test
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=vsl
POSTGRES_PASSWORD=vsl_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mirrormind

# ── Neo4j ────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_secret

# ── OpenAI / OpenAI-compatible provider ──────────────────
# Leave OPENAI_API_KEY empty to use Ollama, LM Studio, etc. via OPENAI_API_BASE.
OPENAI_API_KEY=
# Set for local providers, e.g. http://localhost:11434/v1 (Ollama)
OPENAI_API_BASE=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Auth / JWT ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# REQUIRED in production — the default placeholder will be rejected.
SECRET_KEY=local-dev-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Encryption (Fernet) ─────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Used to encrypt stored credentials (bot tokens, etc.).
# If empty, a key derived from SECRET_KEY is used (development only).
ENCRYPTION_KEY=

# ── CORS ─────────────────────────────────────────────────
# Comma-separated origins. Defaults to localhost dev ports.
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Rate limiting (slowapi) ─────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_GENERATE=30/minute
RATE_LIMIT_UPLOAD=20/minute
RATE_LIMIT_PUBLIC_CHAT=60/minute

# ── Request / upload size limits (bytes) ─────────────────
MAX_REQUEST_BODY_BYTES=26214400
MAX_DOCUMENT_BYTES=15728640
